    {
      "cell_type": "code",
      "source": [
        "from diffusers import StableDiffusionPipeline\n",
        "import torch\n",
        "\n",
        "pipe = StableDiffusionPipeline.from_pretrained(\n",
        "    \"runwayml/stable-diffusion-v1-5\",\n",
        "    torch_dtype=torch.float16\n",
        ")\n",
        "pipe = pipe.to(\"cuda\")\n",
        "pipe.enable_attention_slicing()  
        "print(\"Model loaded successfully!\")"
      ],
      "metadata": {
        "collapsed": true,
        "id": "AJL3QT8oucx2"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "from IPython.display import display\n",
        "\n",
        "prompt = \"a beautiful sunset over the ocean, digital art\"\n",
        "\n",
        "print(\"Generating image... please wait ⏳\")\n",
        "image = pipe(prompt).images[0]\n",
        "display(image)\n",
        "image.save(\"my_first_image.png\")\n",
        "print(\"✅ Image saved!\")\n"
      ],
      "metadata": {
        "id": "gvx1sM40vL6j"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "import matplotlib.pyplot as plt\n",
        "\n",
        "prompts = [\n",
        "    \"a futuristic city at night, neon lights\",\n",
        "    \"a cat sitting on the moon, cartoon style\",\n",
        "    \"a forest with glowing mushrooms, fantasy art\"\n",
        "]\n",
        "\n",
        "images = []\n",
        "for prompt in prompts:\n",
        "    image = pipe(prompt).images[0]\n",
        "    images.append(image)\n",
        "\n",
        "# Show all images together\n",
        "fig, axes = plt.subplots(1, 3, figsize=(15, 5))\n",
        "for i, (img, prompt) in enumerate(zip(images, prompts)):\n",
        "    axes[i].imshow(img)\n",
        "    axes[i].set_title(prompt[:35] + \"...\", fontsize=8)\n",
        "    axes[i].axis(\"off\")\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"all_results.png\")\n",
        "plt.show()\n",
        "print(\"Done!\")"
      ],
      "metadata": {
        "id": "L7XvUid4vXMb"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "for i, image in enumerate(images):\n",
        "    image.save(f\"image_{i+1}.png\")\n",
        "    print(f\"✅ Saved image_{i+1}.png\")"
      ],
      "metadata": {
        "id": "ZY9-FkgtwjMN"
      },
